# Server-side only; do not prefix with VITE_
# Bodhi PAT documentation uses this base URL.
BODHI_API_BASE_URL=https://psaisuite.com/save

# Create in Bodhi Settings -> Personal Access Tokens.
# Required for dashboard Load latest: tasks:read
# Required if later triggering runs from frontend: tasks:execute + workflows:read
# Tokens expire after 2 days; rotate this Railway secret regularly.
BODHI_PAT_TOKEN=pat_replace_with_bodhi_pat

# Required to list latest runs.
BODHI_TASK_ID=replace_with_task_uuid

# Optional: pin to a known run; omit to fetch latest completed run for the task.
BODHI_RUN_ID=

# Optional: use if Bodhi output file path differs from default candidates.
BODHI_OUTPUT_FILE=outputs.json

# Optional fallback if Bodhi cannot be reached.
EVIDENCE_SERVICE_URL=https://ai-visibility-evidence-service-production.up.railway.app
EVIDENCE_RUN_ID=nissan_japan_full_inventory_hobby_v1

DEFAULT_BRAND=Nissan
DEFAULT_MARKET=Japan
