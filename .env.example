# Optional defaults used by the browser UI
VITE_DEFAULT_BRAND=Nissan
VITE_DEFAULT_MARKET=Japan
VITE_EVIDENCE_SERVICE_URL=https://ai-visibility-evidence-service-production.up.railway.app

# Server-side only: do not prefix with VITE_. These are read by server.js on Railway.
# Prefer BODHI_LATEST_RUN_URL if Bodhi exposes a direct latest-output endpoint.
BODHI_API_BASE_URL=https://your-bodhi-host.example.com
BODHI_PAT_TOKEN=replace-with-bodhi-pat
BODHI_WORKFLOW_ID=replace-with-workflow-id
BODHI_TASK_ID=replace-with-task-id
BODHI_RUN_ID=replace-with-run-id-or-leave-empty-if-latest-url-is-used
BODHI_LATEST_RUN_URL=
